{
  "name": "@arguslog/e2e",
  "version": "0.0.0",
  "description": "Arguslog end-to-end tests (Playwright). Real suites land alongside the P2 dashboard.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "test:staging": "ARGUSLOG_E2E_BASE_URL=https://app.arguslog.org ARGUSLOG_E2E_LANDING_URL=https://arguslog.org ARGUSLOG_E2E_API_URL=https://arguslog.org playwright test",
    "test:local": "ARGUSLOG_E2E_BASE_URL=http://localhost:5173 ARGUSLOG_E2E_LANDING_URL=http://localhost:5174 ARGUSLOG_E2E_API_URL=http://localhost:8081 ARGUSLOG_E2E_KEYCLOAK_URL=http://localhost:8180 playwright test",
    "lint": "eslint tests fixtures pages lib",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf playwright-report test-results .turbo"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "typescript": "^5.8.3"
  }
}
