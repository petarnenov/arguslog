{
  "name": "@arguslog/e2e",
  "version": "0.0.0",
  "description": "Arguslog end-to-end tests (Playwright). Real suites land alongside the P2 dashboard.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf playwright-report test-results .turbo"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.8.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.0"
  }
}
