{
  "realm": "arguslog",
  "enabled": true,
  "loginTheme": "arguslog",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "accessTokenLifespan": 900,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeout": 1800,
  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "noreply@arguslog.local",
    "fromDisplayName": "Arguslog",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "arguslog-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://__DEV_HOST__:5173/*",
        "https://arguslog-web-staging.up.railway.app/*",
        "https://app.arguslog.org/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://__DEV_HOST__:5173",
        "https://arguslog-web-staging.up.railway.app",
        "https://app.arguslog.org"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://__DEV_HOST__:5173/*##https://arguslog-web-staging.up.railway.app/*##https://app.arguslog.org/*"
      }
    },
    {
      "clientId": "arguslog-api",
      "enabled": true,
      "publicClient": false,
      "secret": "arguslog-api-dev-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "bearerOnly": true
    },
    {
      "_comment": "Dev-only client for `make seed`. Direct Access Grants (password) is intentionally enabled here so the seed script can mint a user token without going through the browser flow. Production self-hosters can safely delete this client — it only matters for local bootstrap; the main `arguslog-web` flow stays DAG-disabled.",
      "clientId": "arguslog-seed",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "arguslog:user",
        "description": "Standard end-user"
      },
      {
        "name": "arguslog:staff",
        "description": "Internal Arguslog operator"
      }
    ]
  },
  "defaultRoles": ["arguslog:user"]
}
