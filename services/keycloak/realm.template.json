{
  "realm": "arguslog",
  "enabled": true,
  "sslRequired": "none",
  "loginTheme": "arguslog",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "accessTokenLifespan": 900,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeout": 1800,
  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "noreply@arguslog.local",
    "fromDisplayName": "Arguslog",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "arguslog-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://__DEV_HOST__:5173/*",
        "https://arguslog-web-staging.up.railway.app/*",
        "https://app.arguslog.org/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://__DEV_HOST__:5173",
        "https://arguslog-web-staging.up.railway.app",
        "https://app.arguslog.org"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://__DEV_HOST__:5173/*##https://arguslog-web-staging.up.railway.app/*##https://app.arguslog.org/*"
      }
    },
    {
      "clientId": "arguslog-api",
      "enabled": true,
      "publicClient": false,
      "secret": "arguslog-api-dev-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "bearerOnly": true
    },
    {
      "clientId": "arguslog-seed",
      "description": "DEV-ONLY: password-grant client consumed by `make seed`. Production self-hosters can delete this; main browser auth uses `arguslog-web` which keeps DAG disabled.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "arguslog:user",
        "description": "Standard end-user"
      },
      {
        "name": "arguslog:staff",
        "description": "Internal Arguslog operator"
      }
    ]
  },
  "defaultRoles": ["arguslog:user"],
  "identityProviders": [
    {
      "alias": "github",
      "providerId": "github",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "auto-link",
      "config": {
        "clientId": "__GITHUB_CLIENT_ID__",
        "clientSecret": "__GITHUB_CLIENT_SECRET__",
        "syncMode": "IMPORT",
        "defaultScope": "user:email read:user"
      }
    },
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "auto-link",
      "config": {
        "clientId": "__GOOGLE_CLIENT_ID__",
        "clientSecret": "__GOOGLE_CLIENT_SECRET__",
        "syncMode": "IMPORT",
        "defaultScope": "openid email profile"
      }
    },
    {
      "alias": "gitlab",
      "providerId": "gitlab",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "auto-link",
      "config": {
        "clientId": "__GITLAB_CLIENT_ID__",
        "clientSecret": "__GITLAB_CLIENT_SECRET__",
        "syncMode": "IMPORT",
        "defaultScope": "openid email profile read_user"
      }
    }
  ],
  "authenticationFlows": [
    {
      "alias": "auto-link",
      "description": "First-broker-login flow that silently links a fresh IdP login to an existing email-matched user — no consent screen.",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "idp-create-user-if-unique",
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "authenticator": "idp-auto-link",
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        }
      ]
    }
  ]
}
