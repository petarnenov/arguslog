{
  "realm": "argus",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "accessTokenLifespan": 900,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeout": 1800,
  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "noreply@argus.local",
    "fromDisplayName": "Argus",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "argus-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    },
    {
      "clientId": "argus-api",
      "enabled": true,
      "publicClient": false,
      "secret": "argus-api-dev-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "bearerOnly": true
    }
  ],
  "roles": {
    "realm": [
      { "name": "argus:user", "description": "Standard end-user" },
      { "name": "argus:staff", "description": "Internal Argus operator" }
    ]
  },
  "defaultRoles": ["argus:user"],
  "users": [
    {
      "username": "demo@argus.local",
      "email": "demo@argus.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "demo", "temporary": false }],
      "realmRoles": ["argus:user"]
    }
  ]
}
