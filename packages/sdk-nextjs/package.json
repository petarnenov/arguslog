{
  "name": "@arguslog/sdk-nextjs",
  "version": "2.0.0",
  "description": "Arguslog Next.js SDK — App Router + Pages Router, route handler & server action wrappers, instrumentation.ts hook",
  "license": "MIT",
  "type": "module",
  "main": "./dist/client.js",
  "module": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "edge-light": "./dist/server.edge.js",
      "workerd": "./dist/server.edge.js",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "icon.svg"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@arguslog/sdk-node": "workspace:*",
    "@arguslog/sdk-react": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=13.4.0 <16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petarnenov/arguslog-sdks",
    "directory": "packages/sdk-nextjs"
  },
  "homepage": "https://arguslog.org",
  "bugs": {
    "url": "https://github.com/petarnenov/arguslog-sdks/issues"
  }
}
