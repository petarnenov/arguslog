# Copy to .env.local and fill in your project DSN from the Arguslog dashboard.
# The publicKey portion of the DSN is project-scoped and safe to ship in the client bundle.

# Server runtime — read by instrumentation.ts. NEVER prefix with NEXT_PUBLIC_.
ARGUSLOG_DSN=arguslog://YOUR_KEY@localhost:8080/api/1

# Client bundle — inlined at build time by Next.
NEXT_PUBLIC_ARGUSLOG_DSN=arguslog://YOUR_KEY@localhost:8080/api/1

# Release tag — must match the version you upload sourcemaps under in production.
NEXT_PUBLIC_APP_RELEASE=nextjs-todo@1.0.0
