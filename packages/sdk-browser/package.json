{
  "name": "@arguslog/sdk-browser",
  "version": "1.1.3",
  "description": "Arguslog browser SDK \u2014 error tracking for vanilla JS/TS apps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@arguslog/sdk-core": "workspace:*",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "predev": "node scripts/gen-version.mjs",
    "pretest": "node scripts/gen-version.mjs",
    "pretest:coverage": "node scripts/gen-version.mjs",
    "pretest:pact": "node scripts/gen-version.mjs",
    "pretypecheck": "node scripts/gen-version.mjs",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:pact": "vitest run --config vitest.pact.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@pact-foundation/pact": "^13.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petarnenov/arguslog-sdks",
    "directory": "packages/sdk-browser"
  },
  "homepage": "https://arguslog.org",
  "bugs": {
    "url": "https://github.com/petarnenov/arguslog-sdks/issues"
  }
}
