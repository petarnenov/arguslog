{
  "name": "@arguslog/sdk-node",
  "version": "1.0.0",
  "description": "Arguslog Node.js SDK — error tracking for server-side Node apps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:pact": "vitest run --config vitest.pact.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@arguslog/sdk-core": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@pact-foundation/pact": "^13.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.17",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "express": "^5.0.1",
    "supertest": "^7.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
