# Required: DSN copied from your Arguslog project's "Keys" page.
# Format: arguslog://<publicKey>@<ingestHost>/<projectId>
VITE_ARGUSLOG_DSN=arguslog://YOUR_KEY@localhost:8080/1

# Optional: usually the git SHA / package.json version. Bound to source-map artifacts
# uploaded for the same release tag, so symbolication can resolve minified frames.
VITE_ARGUSLOG_RELEASE=react-todo@1.0.0

# Optional: environment label (production | staging | development). Filters dashboards.
VITE_ARGUSLOG_ENV=development
