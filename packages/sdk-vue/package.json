{
  "name": "@arguslog/sdk-vue",
  "version": "1.0.3",
  "description": "Arguslog Vue 3 SDK — plugin, composable, error boundary, errorHandler integration",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@arguslog/sdk-browser": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.18.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.0"
  }
}
