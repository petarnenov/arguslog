{
  "name": "@arguslog/sdk-web3",
  "version": "0.3.0",
  "description": "Arguslog Web3 SDK \u2014 rich error decoding for viem, ethers v6, @solana/web3.js + Anchor, wagmi, WalletConnect (chain, wallet, contract, decoded revert / Anchor / program error)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "icon.svg"
  ],
  "sideEffects": false,
  "dependencies": {
    "@arguslog/sdk-browser": "workspace:*",
    "@arguslog/sdk-core": "workspace:*"
  },
  "peerDependencies": {
    "ethers": "^6.0.0",
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "ethers": "^6.13.0",
    "typescript": "^5.6.0",
    "viem": "^2.21.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "arguslog",
    "error-tracking",
    "web3",
    "ethereum",
    "evm",
    "viem",
    "ethers",
    "solana",
    "monitoring",
    "observability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/petarnenov/arguslog-sdks",
    "directory": "packages/sdk-web3"
  },
  "homepage": "https://arguslog.org",
  "bugs": {
    "url": "https://github.com/petarnenov/arguslog-sdks/issues"
  }
}
