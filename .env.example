# Arguslog self-host configuration.
#
# Copy this file to .env at the repo root and edit the values marked
# "CHANGE ME" before running `docker compose -f infra/docker/docker-compose.full.yml up -d`.
#
# Every value below has a sensible default — uncomment + edit only what your
# deployment actually needs to override.

# ──────────────────────────────────────────────────────────────────────────
# Release / dogfood — bumped by tag-driven CI; safe to leave default
# ──────────────────────────────────────────────────────────────────────────
ARGUSLOG_RELEASE=2.0.0
ARGUSLOG_ENVIRONMENT=self-host
# Pointing your own self-host at itself for dogfooding — paste the
# arguslog://… DSN from your /api/v1/orgs/:id/projects/:id/keys endpoint.
ARGUSLOG_DSN=

# ──────────────────────────────────────────────────────────────────────────
# Postgres
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_USER=arguslog
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=arguslog
POSTGRES_PORT=5432

# ──────────────────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────────
# Keycloak — first-boot admin user. Change the password immediately after
# first login via the Keycloak admin console.
#
# The email below ALSO has to appear in ARGUSLOG_PLATFORM_ADMINS (below) so
# the API guard recognises it as a platform admin once you sign in.
# ──────────────────────────────────────────────────────────────────────────
ARGUSLOG_INITIAL_ADMIN_EMAIL=admin@example.com
ARGUSLOG_INITIAL_ADMIN_PASSWORD=CHANGE_ME_admin_password
KEYCLOAK_PORT=8180
# OIDC issuer URL the API expects. For local docker-compose the internal
# container DNS is `keycloak`; for prod set this to the public KC hostname.
KEYCLOAK_ISSUER=http://keycloak:8180/realms/arguslog

# ──────────────────────────────────────────────────────────────────────────
# Social login (optional). Set both ID + SECRET for either provider to
# enable the matching button on the Keycloak login page. Leaving both
# blank disables that provider; the render-realm.sh script strips the
# IdP from the imported realm so no broken button appears.
#
# Register OAuth apps and copy the credentials in:
#   GitHub:  https://github.com/settings/developers → New OAuth App
#   Google:  https://console.cloud.google.com/apis/credentials
#            → Create Credentials → OAuth client ID (Web application)
#
# Callback URL to register (substitute the right host per environment):
#   Local dev:   http://localhost:8180/realms/arguslog/broker/{github|google}/endpoint
#   Staging:     https://arguslog-keycloak-staging.up.railway.app/realms/arguslog/broker/{github|google}/endpoint
#   Production:  https://auth.arguslog.org/realms/arguslog/broker/{github|google}/endpoint
# ──────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Object store (sourcemaps + attachments). MinIO works locally; for prod
# point at Cloudflare R2 or AWS S3 and update the endpoint + creds.
# ──────────────────────────────────────────────────────────────────────────
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=CHANGE_ME_minio_secret
R2_BUCKET=arguslog-sourcemaps
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ──────────────────────────────────────────────────────────────────────────
# Email (optional). Without RESEND_API_KEY the worker log-and-drops invite
# + alert emails. Mailhog catches them locally on its UI at :8025.
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ──────────────────────────────────────────────────────────────────────────
# Telegram (optional). Without a bot token the worker log-and-drops Telegram
# alert deliveries.
# ──────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Platform admins — comma-separated emails. Matched against the JWT email
# claim. The Keycloak first-boot admin must appear here OR no tier grants
# can ever be issued.
# ──────────────────────────────────────────────────────────────────────────
ARGUSLOG_PLATFORM_ADMINS=admin@example.com

# ──────────────────────────────────────────────────────────────────────────
# Default tier for new sign-ups.
#   regular  — hosted-instance default. Admins grant elevated tiers as needed.
#   silver / gold / platinum — uncapped after sign-up. Use `platinum` for a
#   single-tenant self-host where everyone should be unlimited.
# ──────────────────────────────────────────────────────────────────────────
ARGUSLOG_DEFAULT_TIER=regular

# ──────────────────────────────────────────────────────────────────────────
# API / ingest / worker / web ports — exposed by the compose file
# ──────────────────────────────────────────────────────────────────────────
API_PORT=8081
INGEST_PORT=8080
WORKER_PORT=8082
WEB_PORT=5173

# ──────────────────────────────────────────────────────────────────────────
# CORS — dashboard origin the API will accept browser requests from.
# Production: list your public dashboard URL (https://app.yourdomain.com).
# ──────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────────
# Web build-time env. These are baked into the dashboard image at build,
# not read at runtime — so rebuild the web image whenever you change them.
# For prod, set them to your public URLs (https://api.yourdomain.com, etc.).
# ──────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8081
VITE_INGEST_BASE_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=arguslog
VITE_KEYCLOAK_CLIENT_ID=arguslog-web
