# Local dev — copy to .env (gitignored) if you need to override defaults.
# All services in docker-compose.yml read these via the compose env_file mechanism
# in their respective entries. Most values match what the Spring services expect.

DATABASE_URL=jdbc:postgresql://localhost:5432/argus
DATABASE_USER=argus
DATABASE_PASSWORD=argus
REDIS_URL=redis://localhost:6379
KEYCLOAK_ISSUER=http://localhost:8180/realms/argus
R2_ENDPOINT=http://localhost:9000
R2_BUCKET=argus-sourcemaps
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
