    "@mantine/form": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@mantine/notifications": "^7.15.0",
    "@tabler/icons-react": "^3.26.0",
    "@tanstack/react-query": "^5.66.8",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "oidc-client-ts": "^3.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "react-router": "^7.1.0",
    "recharts": "^2.15.0",
