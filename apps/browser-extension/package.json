{
  "name": "@arguslog/browser-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "prebuild": "wxt prepare",
    "build": "wxt build",
    "zip": "wxt zip",
    "lint": "eslint src tests",
    "pretypecheck": "wxt prepare",
    "typecheck": "tsc -b --noEmit",
    "pretest": "wxt prepare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "clean": "rm -rf dist .output .wxt .turbo node_modules/.tmp"
  },
  "dependencies": {
    "@arguslog/mcp-server": "workspace:*",
    "@arguslog/sdk-react": "workspace:*",
    "@cfworker/json-schema": "^4.1.1",
    "@hookform/resolvers": "^3.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.66.8",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^6.30.1",
    "remark-gfm": "^4.0.1",
    "webextension-polyfill": "^0.12.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@playwright/test": "^1.54.1",
    "@tailwindcss/vite": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.313",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/webextension-polyfill": "^0.10.7",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^9.18.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wxt": "^0.20.26"
  }
}
