{
  "name": "@arguslog/cli",
  "version": "2.0.0",
  "description": "Arguslog CLI — releases, sourcemap upload, project bootstrap",
  "license": "MIT",
  "type": "module",
  "bin": {
    "arguslog": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "icon.svg"
  ],
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "predev": "node scripts/gen-version.mjs",
    "pretest": "node scripts/gen-version.mjs",
    "pretest:coverage": "node scripts/gen-version.mjs",
    "pretypecheck": "node scripts/gen-version.mjs",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@arguslog/eslint-config": "workspace:*",
    "@arguslog/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petarnenov/arguslog-sdks",
    "directory": "cli"
  },
  "homepage": "https://arguslog.org",
  "bugs": {
    "url": "https://github.com/petarnenov/arguslog-sdks/issues"
  }
}
